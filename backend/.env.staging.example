# Servidor
NODE_ENV=staging
PORT=3001
API_VERSION=v1
START_RUN_BOOTSTRAP=false
ENFORCE_HTTPS=true
TRUST_PROXY=1
FRONTEND_URL=https://staging.seu-dominio.com

# Banco de Dados
# Preferencial em cloud (Neon/Vercel): use DATABASE_URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DB_HOST=staging-db-host
DB_PORT=5432
DB_NAME=chamados_ti_staging
DB_USER=chamados_app
DB_PASSWORD=defina-uma-senha-forte
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=defina-uma-chave-com-32-ou-mais-caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email SMTP
SMTP_HOST=smtp.seu-dominio.com
SMTP_PORT=587
SMTP_USER=seu-usuario
SMTP_PASSWORD=sua-senha
SMTP_FROM=noreply@staging.seu-dominio.com

# Configurações Gerais
TIMEZONE=America/Sao_Paulo
MULTIEMPRESA=true
SOFT_DELETE=true
AUDITORIA=true

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=15

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log
